#!/bin/sh
set -e

mkdir -p -- "$LF_CACHE/thumbnails"

case "$(file -b --mime-type -- "$1")" in
	audio/* | image/* | video/*)
		thumbnail="$LF_CACHE/thumbnails/$(printf '%s:%s\n' "$1" "$(stat -c%Y -- "$1")" | base64).png"
		if \
			[ ! -f "$thumbnail" ] &&
			! ffmpeg -i "$1" -frames:v 1 -filter:v scale=256:-1 -- "$thumbnail"
		then
			file -b -- "$1" | fold -sw "$2"
			exit 1
		fi

		chafa \
			--animate=off \
			--polite=on \
			--bg=black \
			--threshold=1 \
			--format=sixel \
			--size="${2}x${3}" \
			-- "$thumbnail"
		;;
	text/*) cat -- "$1" | fold -sw "$2" ;;
	*) file -b -- "$1" | fold -sw "$2" ;;
esac
