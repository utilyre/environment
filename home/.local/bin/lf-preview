#!/bin/sh
set -e

mkdir -p -- "$LF_CACHE/thumbnails"
mime="$(file -b --mime-type -- "$1")"

# genthumb <input> <output>
genthumb() {
	case "$mime" in
		application/pdf) mutool draw -w 256 -o "$2" "$1" 1 ;;
		*) ffmpeg -i "$1" -frames:v 1 -filter:v scale=256:-1 -- "$2" ;;
	esac
}

case "$mime" in
	application/pdf | audio/* | image/* | video/*)
		thumbnail="$LF_CACHE/thumbnails/$(printf '%s:%s\n' "$1" "$(stat -c%Y -- "$1")" | base64).png"
		if [ ! -f "$thumbnail" ] && ! genthumb "$1" "$thumbnail"
		then
			file -b -- "$1" | fold -sw "$2"
			exit 1
		fi

		chafa \
			--animate=off \
			--polite=on \
			--bg=black \
			--threshold=1 \
			--format=sixel \
			--size="${2}x${3}" \
			-- "$thumbnail"
		;;
	text/*) cat -- "$1" | fold -sw "$2" ;;
	*) file -b -- "$1" | fold -sw "$2" ;;
esac
